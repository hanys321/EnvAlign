# ============================================
# EnvAlign 配置文件
# 复制此文件为 .env 并填入你的 API Key
# ============================================

# 智谱AI (GLM) — 注册 https://open.bigmodel.cn 免费额度
ZHIPU_API_KEY=your_zhipu_api_key_here

# 阿里云 DashScope (通义千问) — 注册 https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DeepSeek — 注册 https://platform.deepseek.com 免费额度
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 火山引擎 豆包 — 注册 https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_api_key_here
